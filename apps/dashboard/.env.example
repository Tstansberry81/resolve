# Dashboard (Next.js) env — set these on the Render dashboard service.
# NEXT_PUBLIC_* are inlined at BUILD time, so a change to them needs a rebuild.

# ── Control plane ──────────────────────────────────────────────────────────
# Base URL of the FastAPI control plane the dashboard talks to.
CONTROL_PLANE_URL=

# ── Voice: text-to-speech (ElevenLabs) ─────────────────────────────────────
ELEVENLABS_API_KEY=
# Voice + model. Defaults: Daniel (British, Jarvis-ish) on eleven_turbo_v2_5
# (natural + low-latency). Swap the voice id to change the voice identity.
ELEVENLABS_VOICE_ID=onwK4e9ZLuTAKqWW03F9
ELEVENLABS_MODEL=eleven_turbo_v2_5
# Speaking rate 0.7–1.2 (1.0 natural, 1.05 default = a touch brisk).
ELEVENLABS_SPEED=1.05
# Streaming latency 0–4: higher = faster first audio, slightly less consistent.
ELEVENLABS_STREAM_LATENCY=3

# ── Voice: speech-to-text ──────────────────────────────────────────────────
# Batch fallback model (used if realtime is off or the socket fails).
ELEVENLABS_STT_MODEL=scribe_v1
# Realtime Scribe v2 streaming STT is ON by default in the desktop app. Set to
# 0 to force the batch recognizer. (Requires a plan with Scribe v2 realtime.)
NEXT_PUBLIC_REALTIME_STT=1
# Trailing silence (secs) before the server commits an utterance (0.3–3.0).
NEXT_PUBLIC_STT_VAD_SILENCE_SECS=0.55

# ── Voice: wake word (Picovoice Porcupine, on-device, instant) ─────────────
# THE fix for snappy wake. Free key from https://console.picovoice.ai
# Without it, wake falls back to slow round-trip STT matching.
NEXT_PUBLIC_PICOVOICE_ACCESS_KEY=
# Optional: phrase trained in-browser (default "hey resolve"). No console trip.
NEXT_PUBLIC_WAKE_PHRASE=hey resolve
# Optional: a custom .ppn trained in the Picovoice console, served from /public
# (e.g. /wake/resolve.ppn). Takes precedence over the phrase above.
NEXT_PUBLIC_WAKE_KEYWORD_PATH=
